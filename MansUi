    -- Resize Handle (if resizable)
    if window.Resizable then
        local ResizeHandle = Instance.new("ImageButton")
        ResizeHandle.Name = "ResizeHandle"
        ResizeHandle.Size = UDim2.new(0, 15, 0, 15)
        ResizeHandle.Position = UDim2.new(1, -15, 1, -15)
        ResizeHandle.BackgroundTransparency = 1
        ResizeHandle.Image = "rbxassetid://6031094678"
        ResizeHandle.ImageColor3 = window.Theme.TextSecondary
        ResizeHandle.Parent = MainFrame
        
        -- Resize functionality
        ResizeHandle.MouseButton1Down:Connect(function()
            window.Resizing = true
            local startPos = Mouse.ViewSizeX - MainFrame.AbsolutePosition.X - MainFrame.AbsoluteSize.X
            local startSize = MainFrame.Size
            local conn
            conn = RunService.RenderStepped:Connect(function()
                if window.Resizing then
                    local newWidth = math.clamp(Mouse.X - MainFrame.AbsolutePosition.X + startPos, window.MinSize.X, window.MaxSize.X)
                    local newHeight = math.clamp(Mouse.Y - MainFrame.AbsolutePosition.Y + startPos, window.MinSize.Y, window.MaxSize.Y)
                    MainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
                else
                    conn:Disconnect()
                end
            end)
        end)
        
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                window.Resizing = false
            end
        end)
    end
    
    -- Tab Container
    local TabContainer = Instance.new("Frame")
    TabContainer.Name = "TabContainer"
    TabContainer.Size = UDim2.new(1, 0, 0, 45)
    TabContainer.Position = UDim2.new(0, 0, 0, 40)
    TabContainer.BackgroundColor3 = window.Theme.Surface
    TabContainer.BackgroundTransparency = config.Transparent and 0.1 or 0
    TabContainer.BorderSizePixel = 0
    TabContainer.Parent = MainFrame
    
    local TabContainerCorner = Instance.new("UICorner")
    TabContainerCorner.CornerRadius = UDim.new(0, 8)
    TabContainerCorner.Parent = TabContainer
    
    local TabContainerStroke = Instance.new("UIStroke")
    TabContainerStroke.Thickness = 1
    TabContainerStroke.Color = window.Theme.Border
    TabContainerStroke.Parent = TabContainer
    
    -- Tab List
    local TabList = Instance.new("ScrollingFrame")
    TabList.Name = "TabList"
    TabList.Size = UDim2.new(1, -20, 1, 0)
