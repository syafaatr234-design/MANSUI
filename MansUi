    MinimizeBar.BorderSizePixel = 0
    MinimizeBar.Visible = false
    MinimizeBar.Parent = MainFrame
    
    local MinimizeBarCorner = Instance.new("UICorner")
    MinimizeBarCorner.CornerRadius = UDim.new(0, 8)
    MinimizeBarCorner.Parent = MinimizeBar
    
    local MinimizeBarStroke = Instance.new("UIStroke")
    MinimizeBarStroke.Thickness = 1
    MinimizeBarStroke.Color = window.Theme.Border
    MinimizeBarStroke.Parent = MinimizeBar
    
    local MinimizeBarText = Instance.new("TextLabel")
    MinimizeBarText.Name = "MinimizeBarText"
    MinimizeBarText.Size = UDim2.new(1, -40, 1, 0)
    MinimizeBarText.Position = UDim2.new(0, 10, 0, 0)
    MinimizeBarText.BackgroundTransparency = 1
    MinimizeBarText.Text = window.Title .. " (Minimized)"
    MinimizeBarText.TextColor3 = window.Theme.Text
    MinimizeBarText.TextXAlignment = Enum.TextXAlignment.Left
    MinimizeBarText.Font = Enum.Font.Gotham
    MinimizeBarText.TextSize = 14
    MinimizeBarText.Parent = MinimizeBar
    
    local MaximizeButton = Instance.new("ImageButton")
    MaximizeButton.Name = "MaximizeButton"
    MaximizeButton.Size = UDim2.new(0, 25, 0, 25)
    MaximizeButton.Position = UDim2.new(1, -30, 0.5, -12.5)
    MaximizeButton.BackgroundColor3 = window.Theme.Primary
    MaximizeButton.BackgroundTransparency = 0.3
    MaximizeButton.BorderSizePixel = 0
    MaximizeButton.Image = "rbxassetid://3926305904"
    MaximizeButton.ImageRectOffset = Vector2.new(260, 4)
    MaximizeButton.ImageRectSize = Vector2.new(24, 24)
    MaximizeButton.ImageColor3 = window.Theme.Text
    MaximizeButton.Visible = false
    MaximizeButton.Parent = MainFrame
    
    local MaximizeCorner = Instance.new("UICorner")
    MaximizeCorner.CornerRadius = UDim.new(0, 4)
    MaximizeCorner.Parent = MaximizeButton
    
    -- Minimize/Maximize functionality
    MinimizeButton.MouseButton1Click:Connect(function()
        window.Minimized = true
        MainFrame:TweenSize(UDim2.new(window.Size.X, 0, 40), "Out", "Quad", 0.2, true)
        wait(0.2)
        TabContainer.Visible = false
        ContentContainer.Visible = false
        MinimizeBar.Visible = true
        MaximizeButton.Visible = true
        MinimizeBar.Position = UDim2.new(0, 0, 0, 0)
    end)
    
    MaximizeButton.MouseButton1Click:Connect(function()
        window.Minimized = false
        TabContainer.Visible = true
        ContentContainer.Visible = true
        MinimizeBar.Visible = false
        MaximizeButton.Visible = false
        MinimizeBar.Position = UDim2.new(0, 0, 0, -40)
        MainFrame:TweenSize(window.Size, "Out", "Quad", 0.2, true)
    end)
    
    -- Exit button
    ExitButton.MouseButton1Click:Connect(function()
        ScreenGui:Destroy()
    end)
    
    -- Key System (if enabled)
