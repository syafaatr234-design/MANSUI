        if config.User.Callback then
            UserButton.MouseButton1Click:Connect(config.User.Callback)
        end
        
        -- Reorder controls
        UserButton.Parent = ControlsFrame
        MinimizeButton.Parent = ControlsFrame
        ExitButton.Parent = ControlsFrame
    end
    
    -- Window methods
    function window:AddTab(config)
        local tab = {}
        tab.Title = config.Title or "Tab"
        tab.Sections = {}
        
        -- Create Tab Button
        local TabButton = Instance.new("TextButton")
        TabButton.Name = "TabButton_"..tab.Title
        TabButton.Size = UDim2.new(0, 0, 0, 30)
        TabButton.BackgroundColor3 = window.Theme.Primary
        TabButton.BackgroundTransparency = 0.5
        TabButton.BorderSizePixel = 0
        TabButton.Text = "  " .. tab.Title .. "  "
        TabButton.TextColor3 = window.Theme.TextSecondary
        TabButton.Font = Enum.Font.Gotham
        TabButton.TextSize = 13
        TabButton.AutomaticSize = Enum.AutomaticSize.X
        TabButton.Parent = TabList
        
        local TabButtonCorner = Instance.new("UICorner")
        TabButtonCorner.CornerRadius = UDim.new(0, 4)
        TabButtonCorner.Parent = TabButton
        
        -- Create Tab Content Frame
        local TabFrame = Instance.new("Frame")
        TabFrame.Name = "TabFrame_"..tab.Title
        TabFrame.Size = UDim2.new(1, 0, 1, 0)
        TabFrame.BackgroundTransparency = 1
        TabFrame.Visible = false
        TabFrame.Parent = ContentScrolling
        
        local TabLayout = Instance.new("UIListLayout")
        TabLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        TabLayout.SortOrder = Enum.SortOrder.LayoutOrder
        TabLayout.Padding = UDim.new(0, 10)
        TabLayout.Parent = TabFrame
        
        local TabPadding = Instance.new("UIPadding")
        TabPadding.PaddingLeft = UDim.new(0, 5)
        TabPadding.PaddingRight = UDim.new(0, 5)
        TabPadding.Parent = TabFrame
        
        -- Tab switching
        TabButton.MouseButton1Click:Connect(function()
            for _, otherTab in pairs(window.Tabs) do
                otherTab.Frame.Visible = false
                otherTab.Button.BackgroundTransparency = 0.5
                otherTab.Button.TextColor3 = window.Theme.TextSecondary
            end
            TabFrame.Visible = true
            TabButton.BackgroundTransparency = 0
            TabButton.TextColor3 = window.Theme.Text
            window.CurrentTab = tab
        end)
        
        -- Select first tab by default
        if #window.Tabs == 0 then
            TabFrame.Visible = true
            TabButton.BackgroundTransparency = 0
            TabButton.TextColor3 = window.Theme.Text
        end
        
        tab.Button = TabButton
        tab.Frame = TabFrame
        
        -- Tab methods
        function tab:AddSection(config)
